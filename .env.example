# Example environment variables for local development and Vercel/Supabase
# Copy to `.env.local` for local development and fill values.


DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.gznibdvlupmdqxnzxdvm.supabase.co:5432/postgres?schema=public"
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.gznibdvlupmdqxnzxdvm.supabase.co:5432/postgres"

# NextAuth (required in production)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace_with_secure_random_hex_32_bytes"

# Google OAuth (for Sign-In and Gmail scope)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Vercel: set the following env vars in Project Settings (Production & Preview)
# - DATABASE_URL (use Supabase connection string)
# - DIRECT_URL
# - NEXTAUTH_URL (https://<your-vercel-domain>)
# - NEXTAUTH_SECRET
# - GOOGLE_CLIENT_ID
# - GOOGLE_CLIENT_SECRET

# Optional: other third-party secrets (set if used)
# GMAIL_* or other keys are managed via OAuth in this project; set if needed.
